<?xml version="1.0" encoding="utf-8"?>
<!--
  Repository-local NuGet configuration.

  The agent-swarm messaging gateway only consumes public packages from nuget.org. The
  <clear /> tag on every section is intentional: it prevents inherited machine-wide /
  user-wide registrations (for example, internal Azure DevOps feeds that are unreachable
  from build environments outside the Microsoft corporate network) from being added to
  the restore search list. Without this, `dotnet restore` and the NuGet audit
  (NU1900) report Warning-as-Error failures when those feeds time out, breaking the
  build even when every required package is already cached from nuget.org.

  Audit sources are explicitly pinned to nuget.org so the security audit succeeds
  against the same set of packages the restore actually uses.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
  <auditSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </auditSources>
  <disabledPackageSources>
    <clear />
  </disabledPackageSources>
</configuration>
