{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Slack": {
    "MaxWorkspaces": 15,
    "MembershipCacheTtlMinutes": 5,
    "Retry": {
      "MaxAttempts": 5,
      "InitialDelayMilliseconds": 200,
      "MaxDelaySeconds": 30
    },
    "Signature": {
      "Enabled": true,
      "ClockSkewMinutes": 5,
      "PathPrefix": "/api/slack",
      "MaxBufferedBodyBytes": 1048576
    },
    "Inbound": {
      "DeadLetterDirectory": "data/slack-inbound-dead-letter"
    },
    "Workspaces": []
  },
  "SecretProvider": {
    "ProviderType": "Environment",
    "RefreshIntervalMinutes": 60
  },
  "ConnectionStrings": {
    "SlackAudit": "Data Source=slack-audit.db"
  }
}
