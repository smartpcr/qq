{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Slack": {
    "MaxWorkspaces": 15,
    "MembershipCacheTtlMinutes": 5,
    "Retry": {
      "MaxAttempts": 5,
      "InitialDelayMilliseconds": 200,
      "MaxDelaySeconds": 30
    },
    "Signature": {
      "Enabled": true,
      "ClockSkewMinutes": 5,
      "PathPrefix": "/api/slack",
      "MaxBufferedBodyBytes": 1048576
    },
    "Inbound": {
      "DeadLetterDirectory": "data/slack-inbound-dead-letter"
    },
    "Outbound": {
      "DefaultTeamId": "",
      "RequestTimeout": "00:00:10",
      "JournalDirectory": "data/slack-outbound-journal",
      "DeadLetterDirectory": "data/slack-outbound-dead-letter"
    },
    "ChatPostMessage": {
      "RequestTimeout": "00:00:10"
    },
    "Retention": {
      "Enabled": true,
      "RetentionDays": 30,
      "SweepInterval": "1.00:00:00",
      "InitialDelay": "00:05:00",
      "BatchSize": 1000
    },
    "Workspaces": []
  },
  "SecretProvider": {
    "ProviderType": "Environment",
    "RefreshIntervalMinutes": 60
  },
  "ConnectionStrings": {
    "SlackAudit": "Data Source=slack-audit.db"
  }
}
