{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Slack": {
    "MaxWorkspaces": 15,
    "MembershipCacheTtlMinutes": 5,
    "Retry": {
      "MaxAttempts": 5,
      "InitialDelayMilliseconds": 200,
      "MaxDelaySeconds": 30
    }
  },
  "SecretProvider": {
    "ProviderType": "Environment",
    "RefreshIntervalMinutes": 60
  }
}
