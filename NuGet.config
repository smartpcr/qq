<?xml version="1.0" encoding="utf-8"?>
<!--
  Repository-scoped NuGet configuration. The <clear /> elements wipe any
  user/machine-level feeds (e.g. Azure DevOps internal feeds that require
  authentication) so the build is reproducible regardless of the host
  machine. Only the public nuget.org feed is required to restore the
  AgentSwarm.Messaging packages.

  Audit (NU1900) checks against unreachable Azure DevOps feeds were
  promoting "vulnerability database unreachable" warnings to errors via
  TreatWarningsAsErrors=true on a developer machine whose user-level
  NuGet.Config registered internal feeds without credentials. Scoping
  sources here eliminates that failure mode for everyone.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
  <auditSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </auditSources>
</configuration>
