<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    Repository scoped NuGet configuration.

    Pins the package sources used to restore the AgentSwarm.Messaging
    solution. Exists so that the Forge build gate (and any developer
    machine with an inherited user level NuGet.config) restores against
    nuget.org only. The project does not consume packages from any
    Microsoft internal Azure DevOps artifact feeds, and pulling NuGet
    vulnerability data from those feeds fails with NU1900, which is
    treated as an error because TreatWarningsAsErrors is enabled in
    Directory.Build.props.
  -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
  <!--
    Re assert empty packageSourceMapping so an inherited mapping cannot
    quietly route a package back through one of the cleared feeds.
  -->
  <packageSourceMapping>
    <clear />
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
  <!--
    auditSources controls which feeds NuGet queries for vulnerability
    data. Restricting this to nuget.org keeps NU1900 from firing when
    the inherited audit sources are unreachable.
  -->
  <auditSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </auditSources>
</configuration>
