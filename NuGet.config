<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    Repo-local NuGet sources. Restricts package restore to the public NuGet.org
    feed so builds succeed on developer machines whose user-level NuGet.config
    pulls in private Azure DevOps feeds (the Teams messaging packages are all
    published to NuGet.org and we do not require any private packages).
  -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
  <!--
    Repo-local override for the NuGet global packages folder. Without this entry, NuGet
    inherits the user-level NuGet.Config setting, which on this build host points at a
    partially-populated CoreXT cache (E:\corext_cache). When the cache is missing one of
    the Microsoft.Bot.* sub-assemblies (Connector / Schema / Streaming / Connector.Streaming)
    the C# compiler fails with CS0006 because <ProjectReference> compile-time metadata
    cannot be resolved. Pinning the folder to the standard %USERPROFILE%\.nuget\packages
    location makes restore self-contained: missing packages are downloaded fresh into a
    location NuGet always controls, instead of trusting a shared external cache. NuGet
    natively expands %ENV_VAR% tokens, so the value below works on any Windows host.
  -->
  <config>
    <add key="globalPackagesFolder" value="%USERPROFILE%\.nuget\packages" />
  </config>
  <!--
    Suppress any inherited fallbackPackageFolders so the build never silently picks up
    a stale assembly from a parent cache that is missing transitive packages.
  -->
  <fallbackPackageFolders>
    <clear />
  </fallbackPackageFolders>
</configuration>
