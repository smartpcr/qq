<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    Repo-local NuGet sources. Pins package restore to the public NuGet.org feed so the
    solution builds deterministically on any machine whose user-level NuGet.Config
    inherits private feeds (the Teams messaging packages are all on NuGet.org and the
    solution has no private package dependencies).
  -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
  <!--
    Pin the NuGet global packages folder to the canonical per-user location so restore
    is self-contained and never inherits a partially-populated cache from a parent
    NuGet.Config. NuGet expands %ENV_VAR% tokens, so the value below works on any
    Windows host without requiring a machine-specific override.
  -->
  <config>
    <add key="globalPackagesFolder" value="%USERPROFILE%\.nuget\packages" />
  </config>
  <!--
    Clear inherited fallbackPackageFolders so the build never silently picks up a
    stale assembly from a parent cache that is missing transitive packages.
  -->
  <fallbackPackageFolders>
    <clear />
  </fallbackPackageFolders>
</configuration>
