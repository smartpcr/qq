<?xml version="1.0" encoding="utf-8"?>
<!--
  Repository-local NuGet feed configuration. Pins package resolution and
  vulnerability auditing to nuget.org. The default machine-level NuGet
  configuration on developer/CI hosts in this org points at internal
  msazure.pkgs feeds that require credentials and are unreachable from the
  build environments this solution targets. Without this override the
  upstream feeds raise NU1301 / NU1900 errors before any compilation runs
  (and `TreatWarningsAsErrors=true` in Directory.Build.props promotes NU1900
  to a fatal error). Clearing `packageSources` and `auditSources` here keeps
  restore deterministic and hermetic across machines.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
  <auditSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </auditSources>
</configuration>
